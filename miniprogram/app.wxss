/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 通用卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #1AAD19;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-secondary {
  background-color: #ffffff;
  color: #1AAD19;
  border: 2rpx solid #1AAD19;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

/* 通用列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-label {
  font-size: 28rpx;
  color: #666666;
  width: 160rpx;
}

.list-item-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

/* 通用状态标签 */
.status-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-success {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-warning {
  background-color: #fff8e1;
  color:ffc107;
}

.status-danger {
  background-color: #ffebee;
  color: #f44336;
}

.status-info {
  background-color: #e3f2fd;
  color: #2196f3;
}

/* 通用空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state-icon {
  font-size: 100rpx;
  color: #cccccc;
  margin-bottom: 24rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}
