/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1AAD19 0%, #179f16 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.login-box {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.logo {
  width: 160rpx;
  height: 160rpx;
  display: block;
  margin: 0 auto 32rpx;
}

.title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 60rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.eye-icon {
  width: 40rpx;
  height: 40rpx;
  padding: 8rpx;
}

.login-btn {
  background-color: #1AAD19;
  color: #ffffff;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 40rpx;
  border: none;
}

.login-btn::after {
  border: none;
}

.wechat-login {
  margin-top: 48rpx;
  text-align: center;
}

.divider {
  display: block;
  position: relative;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.divider::before,
.divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 120rpx;
  height: 1rpx;
  background-color: #eeeeee;
}

.divider::before {
  left: 0;
}

.divider::after {
  right: 0;
}

.wechat-btn {
  background-color: #07c160;
  color: #ffffff;
  border-radius: 12rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
}

.wechat-btn::after {
  border: none;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.tips {
  margin-top: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
}
