/* pages/elderly/detail/detail.wxss */

/* 快速呼叫栏 */
.quick-call-bar {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.call-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  width: 30%;
}

.call-btn text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.call-icon {
  width: 48rpx;
  height: 48rpx;
}

.call-btn.emergency {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #fff;
}

.call-btn.care {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}

.call-btn.other {
  background: #f5f5f5;
  color: #666;
}

.info-list {
  padding: 0 8rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666666;
}

.value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.care-list {
  padding: 0 8rpx;
}

.care-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.care-item:last-child {
  border-bottom: none;
}

.care-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.care-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.care-time {
  font-size: 24rpx;
  color: #999999;
}

.care-content {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}

.care-staff,
.care-notes {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.care-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.care-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.more {
  font-size: 26rpx;
  color: #1AAD19;
}

.health-list {
  padding: 0 8rpx;
}

.health-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.health-item:last-child {
  border-bottom: none;
}

.health-label {
  font-size: 28rpx;
  color: #666666;
}

.health-value {
  font-size: 32rpx;
  color: #1AAD19;
  font-weight: 600;
}

/* 健康数据网格 */
.health-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 10rpx;
}

.health-card {
  width: calc(33.33% - 12rpx);
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e7ed 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  box-sizing: border-box;
}

.health-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 0 auto 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.health-icon.blood_pressure {
  background: linear-gradient(135deg, #f56c6c 0%, #e6323e 100%);
}

.health-icon.blood_sugar {
  background: linear-gradient(135deg, #e6a23c 0%, #d4850b 100%);
}

.health-icon.temperature {
  background: linear-gradient(135deg, #409eff 0%, #1a73e8 100%);
}

.health-icon.weight {
  background: linear-gradient(135deg, #67c23a 0%, #4a9c2d 100%);
}

.health-icon.heart_rate {
  background: linear-gradient(135deg, #909399 0%, #6b6e73 100%);
}

.health-info {
  margin-bottom: 6rpx;
}

.health-card .health-value {
  font-size: 28rpx;
  color: #303133;
  font-weight: 600;
}

.health-unit {
  font-size: 20rpx;
  color: #909399;
}

.health-card .health-label {
  font-size: 22rpx;
  color: #606266;
}

/* 健康历史弹窗 */
.health-history {
  padding: 20rpx;
  height: 100%;
  box-sizing: border-box;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e4e7ed;
}

.history-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
}

.history-close {
  font-size: 28rpx;
  color: #409eff;
}

.chart-container {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e4e7ed;
  margin-bottom: 20rpx;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #606266;
  margin-bottom: 6rpx;
}

.bar {
  width: 40rpx;
  background: linear-gradient(180deg, #409eff 0%, #79bbff 100%);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 20rpx;
  max-height: 150rpx;
}

.bar-date {
  font-size: 18rpx;
  color: #909399;
  margin-top: 6rpx;
  transform: scale(0.8);
}

.history-list {
  max-height: 300rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-value {
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
}

.history-time {
  font-size: 24rpx;
  color: #909399;
}
