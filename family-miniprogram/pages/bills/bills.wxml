<!-- pages/bills/bills.wxml -->
<view class="container">
  <!-- 账单统计 -->
  <view class="bill-stats">
    <view class="stat-item">
      <text class="stat-value">{{stats.pendingAmount}}</text>
      <text class="stat-label">待缴费(元)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.paidAmount}}</text>
      <text class="stat-label">本月已付(元)</text>
    </view>
  </view>

  <!-- 账单列表 -->
  <view class="bill-list">
    <view class="bill-item" wx:for="{{bills}}" wx:key="id">
      <view class="bill-header">
        <view class="bill-title">{{item.title}}</view>
        <view class="bill-status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="bill-body">
        <view class="bill-amount">¥{{item.amount}}</view>
        <view class="bill-period">{{item.period}}</view>
      </view>
      <view class="bill-footer">
        <text class="bill-date">{{item.dueDate}}</text>
        <button wx:if="{{item.canPay}}" size="mini" type="primary" bindtap="payBill" data-id="{{item.id}}">立即支付</button>
        <button wx:if="{{item.status === 'paid'}}" size="mini" disabled>已支付</button>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{bills.length === 0}}">
    <text>暂无账单</text>
  </view>
</view>
