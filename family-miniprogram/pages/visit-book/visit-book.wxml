<!-- pages/visit-book/visit-book.wxml -->
<view class="container">
  <form bindsubmit="submitBook">
    <!-- 探视日期 -->
    <view class="form-item">
      <view class="form-label">探视日期 <text class="required">*</text></view>
      <picker mode="date" start="{{today}}" value="{{form.date}}" bindchange="onDateChange">
        <view class="picker">
          {{form.date || '请选择日期'}}
        </view>
      </picker>
    </view>

    <!-- 探视时间 -->
    <view class="form-item">
      <view class="form-label">探视时间 <text class="required">*</text></view>
      <picker mode="time" value="{{form.startTime}}" end="20:00" bindchange="onStartTimeChange">
        <view class="picker-inline">
          {{form.startTime || '开始时间'}}
        </view>
      </picker>
      <text style="margin: 0 10px;">-</text>
      <picker mode="time" value="{{form.endTime}}" start="{{form.startTime}}" end="20:00" bindchange="onEndTimeChange">
        <view class="picker-inline">
          {{form.endTime || '结束时间'}}
        </view>
      </picker>
    </view>

    <!-- 探视人数 -->
    <view class="form-item">
      <view class="form-label">探视人数 <text class="required">*</text></view>
      <input class="input" type="number" name="visitors" placeholder="请输入探视人数" value="{{form.visitors}}" bindinput="onVisitorsInput" />
    </view>

    <!-- 探视人姓名 -->
    <view class="form-item">
      <view class="form-label">探视人姓名 <text class="required">*</text></view>
      <input class="input" name="visitor_name" placeholder="请输入姓名" value="{{form.visitorName}}" bindinput="onNameInput" />
    </view>

    <!-- 联系电话 -->
    <view class="form-item">
      <view class="form-label">联系电话 <text class="required">*</text></view>
      <input class="input" type="tel" name="phone" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onPhoneInput" />
    </view>

    <!-- 关系 -->
    <view class="form-item">
      <view class="form-label">与老人关系 <text class="required">*</text></view>
      <picker range="{{relations}}" value="{{form.relationIndex}}" bindchange="onRelationChange">
        <view class="picker">
          {{form.relationIndex >= 0 ? relations[form.relationIndex] : '请选择关系'}}
        </view>
      </picker>
    </view>

    <!-- 备注 -->
    <view class="form-item">
      <view class="form-label">备注</view>
      <textarea class="textarea" name="notes" placeholder="如有特殊情况请备注" value="{{form.notes}}" bindinput="onNotesInput" maxlength="200" />
    </view>

    <!-- 提交按钮 -->
    <view class="form-actions">
      <button formType="submit" type="primary" loading="{{submitting}}">提交预约</button>
      <button formType="reset" type="default">重置</button>
    </view>
  </form>
</view>
