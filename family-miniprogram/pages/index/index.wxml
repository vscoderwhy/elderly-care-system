<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 头部老人信息卡片 -->
  <view class="elderly-card" wx:if="{{elderlyInfo}}">
    <view class="elderly-avatar">
      <image src="/images/elderly-default.png" mode="aspectFill"></image>
    </view>
    <view class="elderly-info">
      <view class="elderly-name">{{elderlyInfo.name}}</view>
      <view class="elderly-detail">
        <text>{{elderlyInfo.gender === 'male' ? '男' : '女'}} · {{elderlyInfo.care_level}}级护理</text>
      </view>
      <view class="elderly-room" wx:if="{{elderlyInfo.bed}}">
        <text>{{elderlyInfo.bed.room_name}} {{elderlyInfo.bed.name}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToHealth">
      <image src="/images/icon-health.png" mode="aspectFit"></image>
      <text>健康报告</text>
    </view>
    <view class="action-item" bindtap="goToVisits">
      <image src="/images/icon-visit.png" mode="aspectFit"></image>
      <text>预约探视</text>
    </view>
    <view class="action-item" bindtap="goToBills">
      <image src="/images/icon-bill.png" mode="aspectFit"></image>
      <text>费用账单</text>
    </view>
    <view class="action-item" bindtap="makeCall">
      <image src="/images/icon-call.png" mode="aspectFit"></image>
      <text>呼叫服务</text>
    </view>
  </view>

  <!-- 今日护理 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">今日护理</text>
      <text class="more" bindtap="goToHealth">更多 ></text>
    </view>
    <view class="care-list" wx:if="{{todayCare.length > 0}}">
      <view class="care-item" wx:for="{{todayCare}}" wx:key="id">
        <view class="care-time">{{item.time}}</view>
        <view class="care-content">
          <view class="care-name">{{item.name}}</view>
          <view class="care-status {{item.status}}">{{item.statusText}}</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text>暂无今日护理记录</text>
    </view>
  </view>

  <!-- 最近通知 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近通知</text>
    </view>
    <view class="notice-list" wx:if="{{notices.length > 0}}">
      <view class="notice-item" wx:for="{{notices}}" wx:key="id" bindtap="viewNotice" data-id="{{item.id}}">
        <view class="notice-icon {{item.type}}"></view>
        <view class="notice-content">
          <view class="notice-title">{{item.title}}</view>
          <view class="notice-time">{{item.time}}</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>
      <text>暂无通知</text>
    </view>
  </view>
</view>
